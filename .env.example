TELEGRAM_BOT_TOKEN=put_your_token_here
# Optional: protect webhook with a secret header check
TELEGRAM_WEBHOOK_SECRET=put_random_secret_here

# Start message rules (shown on /start)
START_RULES_TEXT=Правила:\n1) Не спамить\n2) Не отправлять запрещенный контент

# Partner channels (must be subscribed before "Сгенерировать")
# Comma-separated channel usernames (public channels), e.g. @channel1,@channel2,@channel3
REQUIRED_CHANNELS=@channel1,@channel2,@channel3

# Telegram file proxy (needed for image-to-image without leaking bot token)
TG_PROXY_SECRET=put_random_secret_here

# KIE.ai
KIE_API_KEY=put_your_kie_api_key_here
# Or (legacy name used in some setups):
KIE_API=
# Optional:
KIE_BASE_URL=https://api.kie.ai
# Models (defaults are Grok Imagine endpoints)
KIE_T2I_MODEL=grok-imagine/text-to-image
KIE_T2I_ASPECT_RATIO=1:1
KIE_I2I_MODEL=grok-imagine/image-to-image
# Optional raw JSON (merged into "input" for each task)
KIE_T2I_EXTRA_INPUT_JSON=
KIE_I2I_EXTRA_INPUT_JSON=
KIE_POLL_TIMEOUT_MS=55000
KIE_POLL_INTERVAL_MS=1500
KIE_HTTP_TIMEOUT_MS=45000
KIE_ASSET_TIMEOUT_MS=45000

# Photo stylization flow (/img -> send photo)
IMG_STYLE_PROMPT=В мире дикой природы
