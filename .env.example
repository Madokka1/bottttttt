TELEGRAM_BOT_TOKEN=put_your_token_here
# Optional: protect webhook with a secret header check
TELEGRAM_WEBHOOK_SECRET=put_random_secret_here

# Start message rules (shown on /start)
START_RULES_TEXT=Правила:\n1) Не спамить\n2) Не отправлять запрещенный контент

# Partner channels (must be subscribed before "Сгенерировать")
# Comma-separated channel usernames (public channels), e.g. @channel1,@channel2,@channel3
REQUIRED_CHANNELS=@channel1,@channel2,@channel3

# Google AI Studio (Gemini) image generation/editing
GEMINI_API_KEY=put_your_google_ai_studio_key_here
# Optional model override
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Hugging Face token (free tier works with rate limits)
HF_TOKEN=put_your_hf_token_here
# Optional: text-to-image command (/t2i)
HF_TEXT_TO_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HF_ENDPOINT_URL=https://router.huggingface.co/hf-inference/models/black-forest-labs/FLUX.1-schnell

# Photo stylization flow (/img -> send photo)
IMG_STYLE_PROMPT=В мире дикой природы
HF_IMAGE_TO_IMAGE_MODEL=black-forest-labs/FLUX.1-Kontext-dev
# Providers priority for photo stylization (auto-fallback on 402)
HF_IMAGE_PROVIDERS=wavespeed,replicate,fal-ai
