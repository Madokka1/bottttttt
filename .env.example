TELEGRAM_BOT_TOKEN=put_your_token_here
# Optional: protect webhook with a secret header check
TELEGRAM_WEBHOOK_SECRET=put_random_secret_here

# Hugging Face token (free tier works with rate limits)
HF_TOKEN=put_your_hf_token_here
# Optional overrides
HF_TEXT_TO_IMAGE_MODEL=runwayml/stable-diffusion-v1-5
# If you want to bypass provider mapping resolution, set endpoint directly:
# HF_ENDPOINT_URL=https://router.huggingface.co/hf-inference/models/runwayml/stable-diffusion-v1-5
