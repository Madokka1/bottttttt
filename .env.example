TELEGRAM_BOT_TOKEN=put_your_token_here
# Optional: protect webhook with a secret header check
TELEGRAM_WEBHOOK_SECRET=put_random_secret_here

# Hugging Face token (free tier works with rate limits)
HF_TOKEN=put_your_hf_token_here
# Optional: text-to-image command (/t2i)
HF_TEXT_TO_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HF_ENDPOINT_URL=https://router.huggingface.co/hf-inference/models/black-forest-labs/FLUX.1-schnell

# Photo stylization flow (/img -> send photo)
IMG_STYLE_PROMPT=В мире дикой природы
HF_IMAGE_TO_IMAGE_MODEL=timbrooks/instruct-pix2pix
# HF_IMAGE_ENDPOINT_URL=https://router.huggingface.co/hf-inference/models/timbrooks/instruct-pix2pix
