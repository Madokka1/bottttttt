TELEGRAM_BOT_TOKEN=put_your_token_here
# Optional: protect webhook with a secret header check
TELEGRAM_WEBHOOK_SECRET=put_random_secret_here

# Start message rules (shown on /start)
START_RULES_TEXT=Правила:\n1) Не спамить\n2) Не отправлять запрещенный контент

# Partner channels (must be subscribed before "Сгенерировать")
# Comma-separated channel usernames (public channels), e.g. @channel1,@channel2,@channel3
REQUIRED_CHANNELS=@channel1,@channel2,@channel3

# AI Horde (Stable Horde) — fully free, crowdsourced inference.
# Optional: your API key (anonymous key works but stricter limits)
HORDE_API_KEY=0000000000
# Optional: base URL(s). You can provide multiple fallbacks:
# HORDE_BASE_URLS=https://aihorde.net/api/v2,https://stablehorde.net/api/v2
HORDE_BASE_URLS=https://aihorde.net/api/v2,https://stablehorde.net/api/v2
# Optional: pick models (comma-separated). Leave empty to let Horde choose.
HORDE_MODELS=
# Optional quality/speed knobs
HORDE_STEPS=20
HORDE_WIDTH=512
HORDE_HEIGHT=512
HORDE_DENOISING=0.6
HORDE_TIMEOUT_MS=25000
HORDE_HTTP_TIMEOUT_MS=45000
HORDE_SUBMIT_HTTP_TIMEOUT_MS=45000
HORDE_CHECK_HTTP_TIMEOUT_MS=20000

# Photo stylization flow (/img -> send photo)
IMG_STYLE_PROMPT=В мире дикой природы
